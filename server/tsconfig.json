{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["main.ts", "platform.ts", "migrate-pb.ts", "adapters/**/*.ts", "../core/src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
