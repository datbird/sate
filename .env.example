# ---- Sate configuration (copy to .env for local dev, or pass as -e to the container) ----

# REQUIRED. 32-character key used to encrypt provider API keys at rest (AES-256).
# Generate with:  openssl rand -hex 16
APP_ENCRYPTION_KEY=change-me-32-characters-long-x

# Comma-separated emails that get the in-app Admin panel (providers + model routing).
# Match the emails your auth proxy (Cloudflare Access) lets through.
ADMIN_EMAILS=you@example.com

# How users are identified. Two modes:
#
#   proxy  (default) — an auth proxy in front of Sate authenticates the user and injects their
#                      email as a header. Sate has no login screen. The container MUST be
#                      reachable only through the proxy, or anyone can forge the header.
#
#   apple            — Sate authenticates users itself with Sign in with Apple. The proxy header
#                      is ignored completely, so the origin may be exposed directly. Requires the
#                      Apple OAuth2 provider to be configured on the `users` collection.
AUTH_MODE=proxy

# proxy mode only. The request header your auth proxy injects with the authenticated user's email.
# Default is Cloudflare Access. For oauth2-proxy/Authelia/Authentik use X-Forwarded-Email etc.
AUTH_EMAIL_HEADER=Cf-Access-Authenticated-User-Email

# LOCAL DEV ONLY. Lets you use the app without an auth proxy by pretending to be this user.
# MUST be empty/unset in production, or anyone can access the app as this user.
# DEV_EMAIL=you@example.com

# Optional: auto-create the PocketBase superuser (built-in /_/ dashboard) on first boot.
# SUPERUSER_EMAIL=you@example.com
# SUPERUSER_PASSWORD=a-strong-password
